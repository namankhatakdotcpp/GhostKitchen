# ============================================
# DATABASE CONFIGURATION (PostgreSQL/Neon)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/ghostkitchen

# ============================================
# REDIS CONFIGURATION (Phase 4 - Required for scaling)
# ============================================
# Redis is required for:
# 1. Socket.IO adapter - enables horizontal scaling
# 2. Caching layer - reduces database load by 70-80%
# 3. Job queues (BullMQ) - async email/notification processing
# 4. Rate limiting - distributed request throttling
# 5. Session storage - shared across instances

# Local development:
REDIS_URL=redis://localhost:6379

# Production (e.g., Redis Cloud, AWS ElastiCache):
# REDIS_URL=redis://default:password@host:port

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_long_1234

# Token expiry times
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development

# Server configuration
PORT=5000
HOST=localhost

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# PAYMENT GATEWAY (Cashfree)
# ============================================
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_API_VERSION=2023-08-01

# ============================================
# EMAIL NOTIFICATIONS (Future - SendGrid/AWS SES)
# ============================================
# SENDGRID_API_KEY=your_sendgrid_api_key
# OR
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY=your_access_key
# AWS_SES_SECRET_KEY=your_secret_key

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug

# ============================================
# RATE LIMITING (Redis-based)
# ============================================
# Configured in middlewares/rateLimiter.js:
# - General: 100 requests per 15 minutes
# - Auth: 20 requests per 15 minutes
# - Payments: 5 requests per 1 minute
# - Strict: 10 requests per 1 hour

# ============================================
# CACHING (Redis)
# ============================================
# Cache TTLs configured in utils/cache.js:
# - Menu: 120 seconds
# - Restaurant: 300 seconds
# - Order: 60 seconds
# - Cart: 3600 seconds

# ============================================
# BACKGROUND JOBS (BullMQ on Redis)
# ============================================
# Job types configured in queues/order.queue.js:
# 1. send-order-confirmation - Email after order placement
# 2. send-status-update - Email on status changes
# 3. delivery-partner-assigned - Partner assignment notification
# 4. payment-confirmation - Payment received confirmation

# Retry configuration:
#   Max attempts: 3
#   Backoff: exponential (2s, 4s, 8s)

# ============================================
# WORKER PROCESS (Async Job Processing)
# ============================================
# Run separate worker process:
# $ node src/workers/order.worker.js
#
# Features:
# - Concurrency: 5 jobs simultaneously per worker
# - Graceful shutdown: SIGTERM/SIGINT handlers
# - Production: Run in Docker container or systemd service

# ============================================
# HORIZONTAL SCALING (Multiple Backend Instances)
# ============================================
# With these components, system can handle 100k+ concurrent users:
#
# 1. Load Balancer (nginx/HAProxy) → 3+ backend instances
# 2. Socket.IO Redis Adapter → shared connection state
# 3. Rate Limiter → distributed via Redis
# 4. Cache Layer → shared via Redis
# 5. Session Storage → shared via Redis
# 6. Queue System → shared via Redis
# 7. Worker Pool → separate process(es) for async jobs

# ============================================
# MONITORING & DEBUGGING
# ============================================
# Health endpoint: GET /health
# - Database status
# - Redis status
# - Environment info
# - Timestamp
#
# Debug endpoint: GET /debug-db
# - Lists all restaurants (development only)
#
# Request tracing: All requests get unique X-Request-ID
# - Helps track requests across logs
# - Used for debugging production issues
